class Solution(object):
    def canCompleteCircuit(self, gas, cost):
        curr = 0
        start = 0
        totalc = 0
        totalg = 0
        for i in range(len(gas)):
            totalc += cost[i]
            totalg += gas[i]
        if totalg < totalc:
            return -1
        for i in range(len(gas)):
            
            curr += (gas[i]-cost[i])
            if curr < 0:
                start = i+1
                curr = 0
        return start
