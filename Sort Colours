class Solution(object):
    def sortColors(self, nums):
        n = len(nums)
        mid = 0 
        high = n-1
        low = 0
        while(mid<=high):
            if(nums[mid]==0):
                nums[mid],nums[low] = nums[low] , nums[mid]
                low +=1
                mid +=1
            elif (nums[mid]==1):
                mid +=1
            else:
                nums[high] , nums[mid] = nums[mid] , nums[high]
                high -=1
        



        
